generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// E-COMMERCE CORE (Sản phẩm & Đơn hàng)
// ==========================================

// 1. Danh mục
model Category {
  id        Int        @id @default(autoincrement())
  slug      String     @unique
  name      String
  parentId  Int?
  icon      String?
  color     String?
  isActive  Boolean    @default(true)
  
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]

  @@index([slug])
}

// 2. Sản phẩm Gốc
model Product {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  categoryId  Int
  brand       String?
  description String?   @db.Text
  productType String    @default("standard") // standard, pre-packaged, custom-build
  isActive    Boolean   @default(true)
  customOptions Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  category    Category         @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]

  @@index([categoryId])
  @@index([slug])
}

// 3. Biến thể Sản phẩm
model ProductVariant {
  id            String    @id @default(cuid())
  productId     Int
  sku           String    @unique
  name          String?   
  price         Float     
  originalPrice Float?    
  stockQuantity Int       @default(0)
  images        Json?     
  attributes    Json?     

  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]

  @@index([productId])
  @@index([sku])
}

// 4. Đơn hàng
enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  CREDIT_CARD
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

model Order {
  id              String      @id @default(uuid())
  userId          String?     
  
  customerName    String
  customerPhone   String
  customerEmail   String?
  shippingAddress String
  
  subTotal        Float
  shippingFee     Float       @default(0)
  discount        Float       @default(0)
  totalAmount     Float       
  
  status          OrderStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(COD)
  paymentStatus   PaymentStatus @default(UNPAID)
  
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]

  @@index([customerPhone])
  @@index([createdAt])
}

// 5. Chi tiết Đơn hàng
model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         String
  variantId       String?  
  
  productName     String   
  variantName     String?  
  sku             String   
  price           Float    
  quantity        Int
  customOptions   Json?    
  
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ==========================================
// CMS VIP PRO (Nội dung, SEO, Cấu hình)
// ==========================================

// 6. Cấu hình Website (Settings) - Lưu trữ dạng Key-Value để tránh hardcode (Tên site, Logo, Hotline...)
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

// 7. Menu Điều hướng Động (Tránh hardcode navbar/footer)
model Menu {
  id          String     @id @default(cuid())
  code        String     @unique // VD: HEADER_MAIN, FOOTER_LINKS
  name        String
  items       MenuItem[]
}

model MenuItem {
  id          String     @id @default(cuid())
  menuId      String
  label       String
  url         String
  icon        String?
  parentId    String?
  order       Int        @default(0)

  menu        Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent      MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  children    MenuItem[] @relation("MenuHierarchy")

  @@index([menuId])
}

// 8. Quản lý Trang Tĩnh & SEO (Vd: Về chúng tôi, Liên hệ)
model Page {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  content         String?  @db.Text
  
  // SEO Metadata
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 9. Bài viết & Tin tức (Blog)
model PostCategory {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  posts       Post[]
}

model Post {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String?
  content         String   @db.Text
  image           String?
  categoryId      Int?
  
  // SEO Metadata
  metaTitle       String?
  metaDescription String?

  isActive        Boolean  @default(true)
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category        PostCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

// 10. Đánh giá Khách hàng (Testimonials)
model Testimonial {
  id          Int      @id @default(autoincrement())
  name        String
  role        String?
  content     String   @db.Text
  rating      Float    @default(5)
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// 11. Dự án / Portfolio (Trưng bày công trình)
model Project {
  id          Int      @id @default(autoincrement())
  title       String
  client      String?
  description String?  @db.Text
  image       String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// 12. Quản lý File Media Trung tâm (Assets)
model Asset {
  id          String   @id @default(cuid())
  url         String
  fileName    String
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime @default(now())
}

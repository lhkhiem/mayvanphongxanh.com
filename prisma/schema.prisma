generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// E-COMMERCE CORE (Sản phẩm & Đơn hàng)
// ==========================================

// 1. Danh mục
model Category {
  id         Int     @id @default(autoincrement())
  slug       String  @unique
  name       String
  parentId   Int?
  icon       String?
  color      String?
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  showInFooter Boolean @default(false)

  // Promo Banner fields
  hasPromo         Boolean @default(false)
  promoTitle       String?
  promoDescription String?
  promoBadgeText   String?
  promoBadgeColor  String?
  promoTargetUrl   String?
  promoImageUrl    String?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([slug])
}

// 1.5 Thương hiệu
model Brand {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  name        String
  logo        String?
  description String? @db.Text
  isActive    Boolean @default(true)

  products Product[]
  certificates PartnerCertificate[]
  isPartner    Boolean @default(false)

  @@index([slug])
}

// 2. Sản phẩm Gốc
model Product {
  id             Int     @id @default(autoincrement())
  slug           String  @unique
  name           String
  categoryId     Int
  brandId        Int?
  brand          String?
  images         Json? // Mảng URL ảnh: ["url1", "url2", ...]
  description    String? @db.Text
  productType    String  @default("standard") // standard, pre-packaged, custom-build
  isActive       Boolean @default(true)
  isFeatured     Boolean @default(false)
  customOptions  Json?
  quickSpecs     Json?
  specifications Json?
  manuals        Json?
  drivers        Json?
  rentalTerms    Json?

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  category       Category         @relation(fields: [categoryId], references: [id])
  brandRef       Brand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variants       ProductVariant[]
  policies       ProductPolicy[]
  consumables    Product[]        @relation("ProductConsumables")
  consumableOf   Product[]        @relation("ProductConsumables")
  rentalMachines RentalMachine[]

  @@index([categoryId])
  @@index([slug])
}

// 2.5 Chính sách sản phẩm (Ví dụ: Giao hàng miễn phí, Bảo hành...)
model ProductPolicy {
  id          Int       @id @default(autoincrement())
  icon        String    @default("CheckCircle")
  title       String
  description String?
  products    Product[]
}

// 3. Biến thể Sản phẩm
model ProductVariant {
  id            String  @id @default(cuid())
  productId     Int
  sku           String  @unique
  name          String?
  price         Float
  originalPrice Float?
  stockQuantity Int     @default(0)
  images        Json?
  attributes    Json?

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@index([sku])
}

// 4. Đơn hàng
enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  CREDIT_CARD
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

model Order {
  id     String  @id @default(uuid())
  userId String?

  customerName    String
  customerPhone   String
  customerEmail   String?
  shippingAddress String

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  subTotal    Float
  shippingFee Float @default(0)
  discount    Float @default(0)
  totalAmount Float

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(COD)
  paymentStatus PaymentStatus @default(UNPAID)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          OrderItem[]
  rentalMachines RentalMachine[]

  @@index([customerPhone])
  @@index([createdAt])
}

// 5. Chi tiết Đơn hàng
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   String
  variantId String?

  productName   String
  variantName   String?
  sku           String
  price         Float
  quantity      Int
  customOptions Json?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ==========================================
// CMS VIP PRO (Nội dung, SEO, Cấu hình)
// ==========================================

// 6. Cấu hình Website (Settings) - Lưu trữ dạng Key-Value để tránh hardcode (Tên site, Logo, Hotline...)
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

// 7. Menu Điều hướng Động (Tránh hardcode navbar/footer)
model Menu {
  id    String     @id @default(cuid())
  code  String     @unique // VD: HEADER_MAIN, FOOTER_LINKS
  name  String
  items MenuItem[]
}

model MenuItem {
  id       String  @id @default(cuid())
  menuId   String
  label    String
  url      String
  icon     String?
  parentId String?
  order    Int     @default(0)

  menu     Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent   MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  children MenuItem[] @relation("MenuHierarchy")

  @@index([menuId])
}

// 8. Quản lý Trang Tĩnh & SEO (Vd: Về chúng tôi, Liên hệ)
model Page {
  id      String  @id @default(cuid())
  slug    String  @unique
  title   String
  content String? @db.Text

  // SEO Metadata
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 9. Bài viết & Tin tức (Blog)
model PostCategory {
  id    Int    @id @default(autoincrement())
  slug  String @unique
  name  String
  posts Post[]
}

model Post {
  id         String  @id @default(cuid())
  slug       String  @unique
  title      String
  excerpt    String?
  content    String  @db.Text
  image      String?
  categoryId Int?

  // SEO Metadata
  metaTitle       String?
  metaDescription String?

  isActive    Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category PostCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

// 10. Đánh giá Khách hàng (Testimonials)
model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  role      String?
  content   String   @db.Text
  rating    Float    @default(5)
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// 11. Dự án / Portfolio (Trưng bày công trình)
model Project {
  id          Int      @id @default(autoincrement())
  title       String
  client      String?
  description String?  @db.Text
  image       String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// 12. Quản lý File Media Trung tâm (Assets)
model MediaFolder {
  id        String        @id @default(cuid())
  name      String
  parentId  String?
  parent    MediaFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MediaFolder[] @relation("FolderHierarchy")
  assets    Asset[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// 13. Dịch vụ trọn gói
model Service {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  excerpt     String?
  content     String?  @db.Text
  image       String?
  icon        String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)

  // SEO Metadata
  metaTitle       String?
  metaDescription String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Asset {
  id        String       @id @default(cuid())
  url       String
  fileName  String
  mimeType  String
  sizeBytes Int
  folderId  String?
  folder    MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())
}

// ==========================================
// AUTHENTICATION & USERS
// ==========================================

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String?   @unique
  password  String?
  roleId    String?
  role      Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  customer  Customer?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false) // Các role hệ thống không cho phép xóa
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id     String           @id @default(cuid())
  code   String           @unique // vd: MANAGE_USERS, VIEW_PRODUCTS
  name   String
  module String // vd: SYSTEM, CATALOG, ORDER
  roles  RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ==========================================
// WARRANTY & SERVICE
// ==========================================

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  VOIDED
}

enum WarrantyEventType {
  ACTIVATED
  REPAIR_RECEIVED
  REPAIRING
  REPAIRED
  RETURNED
  NOTE
}

model WarrantyRecord {
  id             String         @id @default(cuid())
  serialNumber   String         @unique
  productName    String
  sku            String?
  customerName   String
  customerPhone  String
  customerEmail  String?
  customerId     String?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  orderId        String?
  orderItemId    Int?
  purchaseDate   DateTime
  warrantyMonths Int            @default(12)
  expiresAt      DateTime
  status         WarrantyStatus @default(ACTIVE)
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  events WarrantyEvent[]

  @@index([serialNumber])
  @@index([customerPhone])
  @@index([customerEmail])
  @@index([expiresAt])
  @@index([status])
}

model WarrantyEvent {
  id         Int               @id @default(autoincrement())
  warrantyId String
  type       WarrantyEventType @default(NOTE)
  title      String
  note       String?           @db.Text
  eventDate  DateTime          @default(now())
  createdAt  DateTime          @default(now())

  warranty WarrantyRecord @relation(fields: [warrantyId], references: [id], onDelete: Cascade)

  @@index([warrantyId])
  @@index([eventDate])
}

// ==========================================
// CUSTOMERS
// ==========================================

model Customer {
  id      String  @id @default(cuid())
  name    String
  phone   String  @unique
  email   String? @unique
  address String?

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  orders     Order[]
  warranties WarrantyRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([email])
}

// ==========================================
// CUSTOMER FEEDBACK & CONTACT
// ==========================================

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum ContactStatus {
  PENDING
  PROCESSED
}

model ContactRequest {
  id        String        @id @default(cuid())
  name      String
  phone     String
  service   String
  message   String        @db.Text
  status    ContactStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// ==========================================
// RENTAL MACHINES (MÁY THUÊ)
// ==========================================

enum RentalStatus {
  ACTIVE
  RETURNED
  MAINTENANCE
  OVERDUE
}

model RentalMachine {
  id String @id @default(cuid())

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  orderItemId Int?

  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productName  String
  sku          String?
  serialNumber String? // Có thể cập nhật sau khi xuất kho

  customerName    String
  customerPhone   String
  customerEmail   String?
  customerAddress String?

  startDate DateTime  @default(now())
  endDate   DateTime?

  status RentalStatus @default(ACTIVE)
  notes  String?      @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([customerPhone])
  @@index([status])
}

// ==========================================
// BANNERS & SLIDERS
// ==========================================

model Slider {
  id                Int      @id @default(autoincrement())
  image             String
  badge             String?
  title             String?  @db.Text
  description       String?  @db.Text
  btnPrimaryLabel   String?
  btnPrimaryUrl     String?
  btnSecondaryLabel String?
  btnSecondaryUrl   String?
  order             Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String
  subTitle  String?
  icon      String?
  url       String?
  image     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// FAQ (Câu hỏi thường gặp)
// ==========================================

model Faq {
  id        Int      @id @default(autoincrement())
  question  String   @db.Text
  answer    String   @db.Text
  category  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// PARTNER (Đối tác chiến lược & Thương hiệu phân phối)
// ==========================================

model PartnerCertificate {
  id         Int      @id @default(autoincrement())
  brandId    Int
  brand      Brand    @relation(fields: [brandId], references: [id])
  badge      String   // Vd: Đối tác Bạc, Đại lý Ủy quyền
  scope      String   // Phạm vi
  region     String   // Khu vực
  validDate  String   // Hiệu lực (e.g., 01/01/2026 - 31/12/2026)
  link       String?  // Link xem chi tiết
  image      String?  // Ảnh giấy chứng nhận / ủy quyền
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([brandId])
}

model PartnerBenefit {
  id          Int      @id @default(autoincrement())
  icon        String   // Icon name (e.g., CheckCircle, ShieldCheck)
  title       String
  description String   @db.Text
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
